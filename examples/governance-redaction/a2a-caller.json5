{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {
      secret: { type: "string" },
    },
    required: ["secret"],
  },

  slots: {
    agent: { kind: "a2a" },
  },

  program: {
    path: "/usr/bin/env",
    args: [
      "python3",
      "-u",
      "-c",
      { file: "./a2a_caller.py" },
    ],
    env: {
      AGENT_URL: "${slots.agent.url}",
      PORT: "8112",
      SECRET: "${config.secret}",
    },
    network: {
      endpoints: [
        { name: "status", port: 8112 },
      ],
    },
  },

  provides: {
    status: { kind: "http", endpoint: "status" },
  },

  exports: {
    status: "status",
  },
}
