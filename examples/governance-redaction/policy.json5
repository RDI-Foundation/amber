{
  manifest_version: "0.1.0",

  program: {
    path: "/usr/bin/env",
    args: [
      "python3",
      "-u",
      "-c",
      { file: "./policy.py" },
    ],
    env: {
      PORT: "8120",
    },
    network: {
      endpoints: [
        { name: "api", port: 8120 },
      ],
    },
  },

  provides: {
    apply: { kind: "http", profile: "policy", endpoint: "api" },
  },

  exports: {
    apply: "apply",
  },
}
