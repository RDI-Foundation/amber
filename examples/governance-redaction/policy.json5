{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {
      redaction_term: { type: "string" },
    },
    required: ["redaction_term"],
  },

  program: {
    path: "/usr/bin/env",
    args: [
      "python3",
      "-u",
      "-c",
      { file: "./policy.py" },
    ],
    env: {
      PORT: "8120",
      REDACTION_TERM: "${config.redaction_term}",
    },
    network: {
      endpoints: [
        { name: "api", port: 8120 },
      ],
    },
  },

  provides: {
    apply: { kind: "http", profile: "policy", endpoint: "api" },
  },

  exports: {
    apply: "apply",
  },
}
