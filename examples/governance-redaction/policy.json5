{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {
      secrets: { type: "array", items: { type: "string" } },
    },
    required: ["secrets"],
  },

  program: {
    path: "/usr/bin/env",
    args: [
      "python3",
      "-u",
      "-c",
      { file: "./policy.py" },
    ],
    env: {
      PORT: "8120",
      REDACTION_TERMS: "${config.secrets}",
    },
    network: {
      endpoints: [
        { name: "api", port: 8120 },
      ],
    },
  },

  provides: {
    apply: { kind: "http", profile: "policy", endpoint: "api" },
  },

  exports: {
    apply: "apply",
  },
}
