{
  manifest_version: "0.3.0",

  program: {
    image: "busybox:1.36",
    entrypoint: [
      "sh",
      "-ceu",
      { file: "./upstream.sh" },
    ],
    network: {
      endpoints: [
        { name: "http", port: 8080, protocol: "http" },
      ],
    },
  },

  provides: {
    api: { kind: "http", endpoint: "http" },
  },

  exports: {
    api: "api",
  },
}
