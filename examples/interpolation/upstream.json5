{
  manifest_version: "0.2.0",

  program: {
    image: "busybox:1.36",
    entrypoint: [
      "sh",
      "-ceu",
      "mkdir -p /www; printf 'upstream\\n' >/www/index.html; exec httpd -f -p 8080 -h /www",
    ],
    network: {
      endpoints: [
        { name: "http", port: 8080, protocol: "http" },
      ],
    },
  },

  provides: {
    api: { kind: "http", endpoint: "http" },
  },

  exports: {
    api: "api",
  },
}
