{
  manifest_version: "0.1.0",
  slots: {
    api: { kind: "http" },
  },
  program: {
    image: "busybox:1.36",
    entrypoint: [
      "sh",
      "-c",
      { file: "./check-dns.sh" },
    ],
    env: {
      API_URL: "${slots.api.url}",
    },
    network: {
      endpoints: [{ name: "http", port: 9000 }],
    },
  },
  provides: {
    http: { kind: "http", endpoint: "http" },
  },
  exports: {
    http: "http",
  },
}
