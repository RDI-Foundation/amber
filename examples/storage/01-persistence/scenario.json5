{
  manifest_version: "0.1.0",
  resources: {
    app_state: {
      kind: "storage",
      params: {
        size: "1Gi",
      },
    },
  },
  program: {
    image: "python:3.13-alpine",
    entrypoint: [
      "sh",
      "-eu",
      "-c",
      { file: "./app.sh" },
    ],
    mounts: [
      { path: "/var/lib/app", from: "resources.app_state" },
    ],
    env: {
      APP_VERSION: "v1",
      APP_INITIAL_STATE: "seeded by v1",
    },
    network: {
      endpoints: [{ name: "http", port: 8080, protocol: "http" }],
    },
  },
  provides: {
    http: { kind: "http", endpoint: "http" },
  },
  exports: {
    http: "http",
  },
}
