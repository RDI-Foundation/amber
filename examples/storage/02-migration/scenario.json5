{
  manifest_version: "0.1.0",
  resources: {
    app_state: {
      kind: "storage",
      params: {
        size: "1Gi",
      },
    },
  },
  components: {
    app: {
      manifest: "./service.json5",
      config: {
        version: "v1",
        initial_state: "seeded by v1",
      },
    },
  },
  bindings: [
    { to: "#app.state", from: "resources.app_state" },
  ],
  exports: {
    http: "#app.http",
  },
}
