{
  manifest_version: "0.4.0",

  config_schema: {
    type: "object",
    properties: {
      launch_code: { type: "string", default: "swordfish" },
      api_key: { type: "string", default: "hunter2" },
    },
    required: ["launch_code", "api_key"],
  },

  use: {
    redaction: {
      manifest: "./overlay.json5",
      config: {
        redaction_terms: ["$${config.launch_code}", "$${config.api_key}"],
      },
    },
  },

  overlays: ["#redaction.apply"],

  components: {
    responder: "./a2a-responder.json5",
    caller: {
      manifest: "./a2a-caller.json5",
      config: {
        launch_code: "${config.launch_code}",
        api_key: "${config.api_key}",
      },
    },
  },

  bindings: [
    { to: "#caller.agent", from: "#responder.a2a" },
  ],

  exports: {
    status: "#caller.status",
  },
}
