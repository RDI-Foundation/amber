{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {
      redaction_terms: {
        type: "array",
        items: { type: "string" },
      },
    },
    required: ["redaction_terms"],
  },

  program: {
    path: "./overlay.py",
    env: {
      PORT: "8120",
      REDACTION_TERMS: "${config.redaction_terms}",
    },
    network: {
      endpoints: [
        { name: "api", port: 8120 },
      ],
    },
  },

  provides: {
    apply: { kind: "http", profile: "overlay", endpoint: "api" },
  },

  exports: {
    apply: "apply",
  },
}
