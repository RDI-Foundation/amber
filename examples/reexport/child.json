{
  "manifest_version": "0.1.0",
  "program": {
    "image": "busybox:stable",
    "entrypoint": [
      "/bin/sh",
      "-c",
      { "file": "./serve.sh" }
    ],
    "network": {
      "endpoints": [{ "name": "endpoint", "port": 8080 }]
    }
  },
  "provides": {
    "cap": { "kind": "http", "endpoint": "endpoint" }
  },
  "exports": { "cap": "cap" }
}
