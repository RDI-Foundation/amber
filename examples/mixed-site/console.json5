{
  manifest_version: "0.3.0",
  slots: {
    queue: { kind: "http" },
  },
  program: {
    path: "/usr/bin/env",
    args: ["python3", "-u", { file: "./console.py" }],
    env: {
      PORT: "8080",
      QUEUE_URL: "${slots.queue.url}",
    },
    network: {
      endpoints: [
        { name: "http", port: 8080, protocol: "http" },
      ],
    },
  },
  provides: {
    http: { kind: "http", endpoint: "http" },
  },
  exports: {
    http: "http",
  },
}
