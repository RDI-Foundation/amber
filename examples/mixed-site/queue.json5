{
  manifest_version: "0.3.0",
  slots: {
    vault: { kind: "http" },
  },
  program: {
    image: "python:3.13-alpine",
    entrypoint: ["python3", "-u", { file: "./queue.py" }],
    env: {
      PORT: "8080",
      VAULT_URL: "${slots.vault.url}",
    },
    network: {
      endpoints: [
        { name: "http", port: 8080, protocol: "http" },
      ],
    },
  },
  provides: {
    http: { kind: "http", endpoint: "http" },
  },
  exports: {
    http: "http",
  },
}
