{
  manifest_version: "0.1.0",

  // Root config on the scenario becomes a backend runtime input. In this example Amber exposes
  // the leaf below as `AMBER_CONFIG_API_KEY` on backends like Compose and Kubernetes.
  config_schema: {
    type: "object",
    properties: {
      api_key: { type: "string" },
      system_prompt: {
        type: "string",
        default: "You are an agent.",
      },
    },
    required: ["api_key", "system_prompt"],
    additionalProperties: false,
  },

  components: {
    api_client: {
      manifest: "./api-client.json5",
      config: {
        // Forward the externally supplied root config into the child's config object.
        api_key: "${config.api_key}",
        // Defaults on the root config schema are materialized before the child config is rendered.
        system_prompt: "${config.system_prompt}",
      },
    },
  },

  exports: { api: "#api_client.api" },
}
