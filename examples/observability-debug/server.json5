{
  manifest_version: "0.1.0",
  program: {
    image: "python:3.13-alpine",
    entrypoint: [
      "sh",
      "-lc",
      { file: "./server.sh" },
    ],
    network: {
      endpoints: [{ name: "api", port: 9000 }],
    },
  },
  provides: {
    api: { kind: "mcp", profile: "debug-jsonrpc", endpoint: "api" },
  },
  exports: {
    api: "api",
  },
}
