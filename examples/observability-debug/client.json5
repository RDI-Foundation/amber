{
  manifest_version: "0.1.0",
  slots: {
    server_api: { kind: "mcp", profile: "debug-jsonrpc" },
    ext_api: { kind: "http", profile: "debug-external" },
  },
  program: {
    image: "busybox:1.36",
    entrypoint: [
      "sh",
      "-lc",
      { file: "./client.sh" },
    ],
    env: {
      SERVER_API_URL: "${slots.server_api.url}",
      EXT_API_URL: "${slots.ext_api.url}",
    },
    network: {
      endpoints: [{ name: "status", port: 9010 }],
    },
  },
  provides: {
    status: { kind: "http", endpoint: "status" },
  },
  exports: {
    status: "status",
  },
}
