{
  manifest_version: "0.1.0",

  program: {
    path: "/usr/bin/env",
    args: [
      "python3",
      "-u",
      "-c",
      { file: "./secret.py" },
    ],
    network: {
      endpoints: [
        { name: "http", port: 8101, protocol: "http" },
      ],
    },
  },

  provides: {
    secret: { kind: "http", endpoint: "http" },
  },

  exports: {
    secret: "secret",
  },
}
