{
  manifest_version: "0.1.0",

  program: {
    path: "/usr/bin/env",
    args: [
      "python3",
      "-u",
      "-c",
      'import http.server, socketserver\nSECRET = b"amber secret: swordfish\\n"\n\nclass Handler(http.server.BaseHTTPRequestHandler):\n    def do_GET(self):\n        self.send_response(200)\n        self.send_header("Content-Type", "text/plain")\n        self.send_header("Content-Length", str(len(SECRET)))\n        self.end_headers()\n        self.wfile.write(SECRET)\n    def log_message(self, fmt, *args):\n        return\n\nsocketserver.TCPServer.allow_reuse_address = True\nwith socketserver.TCPServer(("127.0.0.1", 8101), Handler) as httpd:\n    httpd.serve_forever()\n',
    ],
    network: {
      endpoints: [
        { name: "http", port: 8101, protocol: "http" },
      ],
    },
  },

  provides: {
    secret: { kind: "http", endpoint: "http" },
  },

  exports: {
    secret: "secret",
  },
}
