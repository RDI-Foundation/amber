{
  manifest_version: "0.1.0",

  slots: {
    secret: { kind: "http" },
  },

  program: {
    path: "/usr/bin/env",
    args: [
      "python3",
      "-u",
      "-c",
      'import http.server, os, socketserver, urllib.request\nSECRET_URL = os.environ["SECRET_URL"]\n\ndef fetch_secret():\n    try:\n        with urllib.request.urlopen(SECRET_URL, timeout=2) as resp:\n            return resp.read()\n    except Exception as e:\n        return ("ERROR fetching secret via slot: " + repr(e) + "\\n").encode()\n\nclass Handler(http.server.BaseHTTPRequestHandler):\n    def do_GET(self):\n        secret = fetch_secret()\n        body = b"allowed: secret via slot\\n" + secret\n        self.send_response(200)\n        self.send_header("Content-Type", "text/plain")\n        self.send_header("Content-Length", str(len(body)))\n        self.end_headers()\n        self.wfile.write(body)\n    def log_message(self, fmt, *args):\n        return\n\nsocketserver.TCPServer.allow_reuse_address = True\nwith socketserver.TCPServer(("127.0.0.1", 8102), Handler) as httpd:\n    httpd.serve_forever()\n',
    ],
    env: {
      SECRET_URL: "${slots.secret.url}",
    },
    network: {
      endpoints: [
        { name: "http", port: 8102, protocol: "http" },
      ],
    },
  },

  provides: {
    public: { kind: "http", endpoint: "http" },
  },

  exports: {
    public: "public",
  },
}
