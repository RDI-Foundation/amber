{
  manifest_version: "0.1.0",

  slots: {
    secret: { kind: "http" },
  },

  program: {
    path: "/usr/bin/env",
    args: [
      "python3",
      "-u",
      "-c",
      { file: "./allowed.py" },
    ],
    env: {
      SECRET_URL: "${slots.secret.url}",
    },
    network: {
      endpoints: [
        { name: "http", port: 8102, protocol: "http" },
      ],
    },
  },

  provides: {
    public: { kind: "http", endpoint: "http" },
  },

  exports: {
    public: "public",
  },
}
