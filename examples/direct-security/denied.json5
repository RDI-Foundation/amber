{
  manifest_version: "0.1.0",

  program: {
    path: "/usr/bin/env",
    args: [
      "python3",
      "-u",
      "-c",
      'import http.server, socketserver, urllib.request\nTARGET = "http://127.0.0.1:8101"\n\ndef try_bypass():\n    try:\n        with urllib.request.urlopen(TARGET, timeout=2) as resp:\n            body = resp.read()\n        return b"UNEXPECTED: bypass succeeded\\n" + body\n    except Exception as e:\n        return ("blocked (expected on Linux): " + repr(e) + "\\n").encode()\n\nclass Handler(http.server.BaseHTTPRequestHandler):\n    def do_GET(self):\n        body = b"denied: direct TCP attempt to secret\\n" + try_bypass()\n        self.send_response(200)\n        self.send_header("Content-Type", "text/plain")\n        self.send_header("Content-Length", str(len(body)))\n        self.end_headers()\n        self.wfile.write(body)\n    def log_message(self, fmt, *args):\n        return\n\nsocketserver.TCPServer.allow_reuse_address = True\nwith socketserver.TCPServer(("127.0.0.1", 8103), Handler) as httpd:\n    httpd.serve_forever()\n',
    ],
    network: {
      endpoints: [
        { name: "http", port: 8103, protocol: "http" },
      ],
    },
  },

  provides: {
    public: { kind: "http", endpoint: "http" },
  },

  exports: {
    public: "public",
  },
}
