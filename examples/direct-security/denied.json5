{
  manifest_version: "0.1.0",

  program: {
    path: "/usr/bin/env",
    args: [
      "python3",
      "-u",
      "-c",
      { file: "./denied.py" },
    ],
    network: {
      endpoints: [
        { name: "http", port: 8103, protocol: "http" },
      ],
    },
  },

  provides: {
    public: { kind: "http", endpoint: "http" },
  },

  exports: {
    public: "public",
  },
}
