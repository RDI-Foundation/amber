{
  manifest_version: "0.3.0",
  program: {
    path: "/usr/bin/env",
    args: ["python3", "-u", "-c", { file: "./worker.py" }],
    env: {
      NAME: "worker",
      PORT: "18081",
    },
    network: {
      endpoints: [
        { name: "http", port: 18081, protocol: "http" },
      ],
    },
  },
  provides: {
    http: { kind: "http", endpoint: "http" },
  },
  exports: {
    http: "http",
  },
}
