{
  manifest_version: "0.3.0",
  slots: {
    ctl: { kind: "component" },
  },
  program: {
    path: "/usr/bin/env",
    args: ["python3", "-u", "-c", { file: "./admin.py" }],
    env: {
      NAME: "admin",
      PORT: "18080",
      CTL_URL: "${slots.ctl.url}",
    },
    network: {
      endpoints: [
        { name: "http", port: 18080, protocol: "http" },
      ],
    },
  },
  provides: {
    http: { kind: "http", endpoint: "http" },
  },
  exports: {
    http: "http",
  },
}
