{
  // This probe is intentionally unbound. It hardcodes a guessed guest-side URL to show that
  // guessing an address does not give the VM access.
  manifest_version: "0.1.0",
  config_schema: {
    type: "object",
    properties: {
      base_image: { type: "string" },
    },
    required: ["base_image"],
    additionalProperties: false,
  },
  program: {
    vm: {
      image: "${config.base_image}",
      cpus: 4,
      memory_mib: 1024,
      cloud_init: {
        user_data: { file: "./unbound.cloud-init.yaml" },
      },
      network: {
        endpoints: [
          { name: "http", port: 8080, protocol: "http" },
        ],
        egress: "none",
      },
    },
  },
  provides: {
    http: { kind: "http", endpoint: "http" },
  },
  exports: {
    http: "http",
  },
}
