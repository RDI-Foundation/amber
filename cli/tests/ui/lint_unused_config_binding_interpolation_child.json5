{
  manifest_version: "0.1.0",
  config_schema: {
    type: "object",
    properties: {
      required_value: { type: "string" },
      ignored_value: { type: "string" },
    },
    required: ["required_value"],
  },
  program: {
    image: "ghcr.io/acme/app:v1",
    entrypoint: ["app"],
    env: {
      REQUIRED_VALUE: "${config.required_value}",
      BACKEND_URL: "${slots.backend.url}",
    },
    network: {
      endpoints: [
        { name: "out", port: 8080 },
      ],
    },
  },
  slots: {
    backend: { kind: "http" },
  },
  provides: {
    out: { kind: "http", endpoint: "out" },
  },
  exports: {
    out: "out",
  },
}
