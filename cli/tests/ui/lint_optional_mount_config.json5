{
  manifest_version: "0.3.0",
  config_schema: {
    type: "object",
    properties: {
      file: { type: "string" },
    },
  },
  program: {
    image: "x",
    entrypoint: ["x"],
    mounts: [
      { path: "/tmp/file.txt", from: "config.file" },
    ],
    network: {
      endpoints: [
        { name: "http", port: 8080, protocol: "http" },
      ],
    },
  },
  provides: {
    http: { kind: "http", endpoint: "http" },
  },
  exports: {
    http: "http",
  },
}
