{
  manifest_version: "0.2.0",
  config_schema: {
    type: "object",
    properties: {
      profile: { type: "string" },
    },
  },
  program: {
    path: "/bin/echo",
    args: [
      {
        when: "config.profile",
        argv: ["--api", "${slots.api.blabla}"],
      },
    ],
    network: {
      endpoints: [
        { name: "http", port: 8080, protocol: "http" },
      ],
    },
  },
  slots: {
    api: { kind: "http" },
  },
  provides: {
    http: { kind: "http", endpoint: "http" },
  },
  exports: {
    http: "http",
  },
}
