{
  manifest_version: "0.4.0",
  use: {
    nested: "./use_contains_overlay_nested.json5",
  },
  program: {
    image: "wrapper",
    entrypoint: ["wrapper"],
    network: { endpoints: [{ name: "api", port: 80 }] },
  },
  provides: {
    rewrite: { kind: "http", profile: "overlay", endpoint: "api" },
  },
  exports: {
    rewrite: "rewrite",
  },
}
