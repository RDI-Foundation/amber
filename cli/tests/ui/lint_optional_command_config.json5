{
  manifest_version: "0.1.0",
  config_schema: {
    type: "object",
    properties: {
      profile: { type: "string" },
    },
  },
  program: {
    path: "/bin/echo",
    args: ["--profile", "${config.profile}"],
    network: {
      endpoints: [
        { name: "http", port: 8080, protocol: "http" },
      ],
    },
  },
  provides: {
    http: { kind: "http", endpoint: "http" },
  },
  exports: {
    http: "http",
  },
}
