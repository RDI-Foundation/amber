{
  manifest_version: "0.1.0",
  program: {
    image: "root",
    entrypoint: ["root"],
    network: {
      endpoints: [
        { name: "http", port: 80 },
      ],
    },
  },
  components: {
    child: "./lint_deprecated_self_ref_child.json5",
  },
  provides: {
    api: { kind: "http", endpoint: "http" },
  },
  bindings: [
    { to: "#child.api", from: "self.api" },
  ],
  exports: {
    public: "self.api",
  },
}
