{
  manifest_version: "0.1.0",
  slots: {
    state: { kind: "storage" },
  },
  program: {
    image: "busybox:1.36.1",
    entrypoint: ["sh", "-lc", "sleep infinity"],
    network: {
      endpoints: [
        { name: "http", port: 8080, protocol: "http" },
      ],
    },
    mounts: [
      { path: "/var/lib/app", from: "slots.state" },
    ],
  },
  provides: {
    http: { kind: "http", endpoint: "http" },
  },
  exports: {
    http: "http",
  },
}
