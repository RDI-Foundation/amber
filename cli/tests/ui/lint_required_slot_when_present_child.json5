{
  manifest_version: "0.1.0",
  slots: {
    api: { kind: "http" },
  },
  program: {
    image: "child",
    entrypoint: [
      "child",
      {
        when_present: "slots.api.url",
        argv: ["--peer", "${slots.api.url}"],
      },
    ],
    network: {
      endpoints: [
        { name: "http", port: 8081, protocol: "http" },
      ],
    },
  },
  provides: {
    http: { kind: "http", endpoint: "http" },
  },
  exports: {
    http: "http",
  },
}
